{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "uiux-layout-director",
  "title": "UI/UX Layout Director",
  "version": "0.1.0",
  "description": "Open Design skill for UI/UX, website, menu, dashboard, and navigation layout generation.",
  "license": "MIT",
  "tags": ["uiux", "layout", "website", "menu", "navigation", "dashboard"],
  "od": {
    "kind": "skill",
    "taskKind": "new-generation",
    "useCase": {
      "query": "Design a {{surface}} with strong UI/UX hierarchy for {{audience}}."
    },
    "context": {
      "skills": [{ "ref": "uiux-layout-director" }],
      "atoms": ["navigation-model", "responsive-layout", "component-inventory"]
    },
    "inputs": [
      { "name": "surface", "type": "string", "default": "website" },
      { "name": "audience", "type": "string", "default": "general users" },
      { "name": "style", "type": "string", "default": "modern product UI" }
    ],
    "capabilities": ["prompt:inject", "artifact:html", "design-system:reference"]
  }
}
